<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xindongli.crm.system.mapper.CustomerPoolRuleMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.xindongli.crm.system.entity.CustomerPoolRule">
        <id column="id" property="id"/>
        <result column="rule_name" property="ruleName"/>
        <result column="rule_type" property="ruleType"/>
        <result column="days_threshold" property="daysThreshold"/>
        <result column="rule_description" property="ruleDescription"/>
        <result column="status" property="status"/>
        <result column="priority" property="priority"/>
        <result column="deleted" property="deleted"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 基础字段 -->
    <sql id="Base_Column_List">
        id, rule_name, rule_type, days_threshold, rule_description, status, priority,
        deleted, create_by, create_time, update_by, update_time
    </sql>

    <!-- 根据规则名称查询 -->
    <select id="selectByRuleName" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM crm_customer_pool_rule
        WHERE rule_name = #{ruleName}
        AND deleted = 0
        LIMIT 1
    </select>

</mapper>
