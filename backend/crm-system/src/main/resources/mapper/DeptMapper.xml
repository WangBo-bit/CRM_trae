<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xindongli.crm.system.mapper.DeptMapper">

    <!-- 查询部门树形结构 -->
    <select id="selectDeptTree" resultType="com.xindongli.crm.system.entity.Dept">
        SELECT *
        FROM sys_dept
        WHERE deleted = 0
        ORDER BY order_num ASC
    </select>

    <!-- 根据父部门ID查询子部门数量 -->
    <select id="selectChildrenCountByParentId" resultType="int">
        SELECT COUNT(1)
        FROM sys_dept
        WHERE parent_id = #{parentId}
          AND deleted = 0
    </select>

    <!-- 根据部门ID查询是否存在用户 -->
    <select id="selectUserCountByDeptId" resultType="int">
        SELECT COUNT(1)
        FROM sys_user
        WHERE dept_id = #{deptId}
          AND deleted = 0
    </select>

    <!-- 查询子部门列表 -->
    <select id="selectChildrenByParentId" resultType="com.xindongli.crm.system.entity.Dept">
        SELECT *
        FROM sys_dept
        WHERE parent_id = #{parentId}
          AND deleted = 0
        ORDER BY order_num ASC
    </select>

</mapper>
