<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xindongli.crm.system.mapper.RolePermissionMapper">

    <!-- 根据角色ID删除角色权限关联 -->
    <delete id="deleteByRoleId">
        DELETE FROM sys_role_permission
        WHERE role_id = #{roleId}
    </delete>

    <!-- 根据权限ID删除角色权限关联 -->
    <delete id="deleteByPermissionId">
        DELETE FROM sys_role_permission
        WHERE permission_id = #{permissionId}
    </delete>

    <!-- 批量插入角色权限关联 -->
    <insert id="batchInsert">
        INSERT INTO sys_role_permission (id, role_id, permission_id, created_time)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (UUID(), #{item.roleId}, #{item.permissionId}, #{item.createdTime})
        </foreach>
    </insert>

</mapper>
